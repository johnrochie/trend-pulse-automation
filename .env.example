# NewsAPI Configuration
NEWSAPI_KEY=your_newsapi_key_here

# AI Configuration (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Database Configuration
DATABASE_PATH=./articles.db

# Site Configuration
SITE_URL=https://trend-pulse.vercel.app

# Scheduling
FETCH_INTERVAL_HOURS=6
MAX_ARTICLES_PER_CYCLE=5

# Categories to fetch (comma-separated)
CATEGORIES=technology,business,entertainment

# GitHub Configuration (for update-github.js)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=johnrochie/trend-pulse-automation
GITHUB_BRANCH=main
GITHUB_OUTPUT_FILE=output/articles.json