# ─── Required ──────────────────────────────────────────────────────────────

# NewsAPI key — https://newsapi.org (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# DeepSeek API key — https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# GitHub Personal Access Token with 'repo' scope
# Needs write access to the johnrochie/trend-pulse repository
# Create at: https://github.com/settings/tokens
TREND_PULSE_TOKEN=your_github_pat_here

# ─── Optional ──────────────────────────────────────────────────────────────

# News categories to fetch (comma-separated, no spaces)
# NewsAPI supported: technology, business, entertainment, science, health, sports, general
CATEGORIES=technology,business,entertainment,science,health

# Max articles to generate per run (keep low to stay within API quotas)
MAX_ARTICLES_PER_CYCLE=5

# DeepSeek token limit per article (higher = more detailed articles, higher cost)
MAX_TOKENS=2500

# DeepSeek base URL (change only if using a proxy)
DEEPSEEK_BASE_URL=https://api.deepseek.com
